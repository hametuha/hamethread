{
	"name": "hametuha/hamethread",
	"description": "Forum plugin by hametuha.",
	"type": "wordpress-plugin",
	"license": "GPL-3.0-or-later",
	"scripts": {
		"lint": "phpcs --standard=phpcs.ruleset.xml $(find . -name '*.php')",
		"fix": "phpcbf --standard=phpcs.ruleset.xml $(find . -name '*.php')",
		"test": "phpunit",
		"phpstan": "phpstan analyse --memory-limit=1G"
	},
	"authors": [
		{
			"name": "fumikito",
			"email": "guy@hametuha.com"
		}
	],
	"minimum-stability": "stable",
	"require": {
		"php": ">=7.4",
		"hametuha/pattern": "^1.0"
	},
	"require-dev": {
		"phpunit/phpunit": "^8|^9",
		"wp-coding-standards/wpcs": "^3.0",
		"yoast/phpunit-polyfills": "^4.0",
		"hametuha/hashboard": "^1.0",
		"phpstan/phpstan": "^2.1",
		"szepeviktor/phpstan-wordpress": "^2.0",
		"php-stubs/wordpress-stubs": "^6.9",
		"php-stubs/wp-cli-stubs": "^2.10"
	},
	"autoload": {
		"psr-0": {
			"Hametuha\\Thread": "app"
		}
	},
	"config": {
		"platform": {
			"php": "7.4"
		},
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	}
}
